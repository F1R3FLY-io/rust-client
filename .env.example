# ====================
# F1r3fly Node Connection (Library)
# ====================
# Used by ConnectionConfig::from_env() when using rust-client as a library crate.

# Node hostname (default: localhost)
FIREFLY_HOST=localhost

# gRPC port for deploy/propose operations (default: 40401)
FIREFLY_GRPC_PORT=40401

# HTTP port for status/query operations (default: 40403)
FIREFLY_HTTP_PORT=40403

# Private key for signing deploys (REQUIRED, 64 hex chars)
FIREFLY_PRIVATE_KEY=

# Observer node hostname for finalization checks (default: same as FIREFLY_HOST)
# On a shard, the observer/read-only node is separate from validators.
# FIREFLY_OBSERVER_HOST=localhost

# Observer node gRPC port (default: 40452)
# FIREFLY_OBSERVER_GRPC_PORT=40452

# Maximum seconds to wait for a deploy to be included in a block (default: 60)
# FIREFLY_DEPLOY_TIMEOUT=60

# Maximum seconds to wait for block finalization (default: 30)
# FIREFLY_FINALIZATION_TIMEOUT=30
